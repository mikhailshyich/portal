<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Заголовок модального окна</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body">
                @Message
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" @onclick="() => OnResult(false)">Закрыть</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" @onclick="() => OnResult(true)">Сохранить изменения</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Message { get; set; }
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    void OnResult(bool result)
    {
        OnClose.InvokeAsync(result);
    }
}